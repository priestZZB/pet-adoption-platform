<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- 引入 Spring Boot 默认日志配置（控制台 + 文件） -->
    <include resource="org/springframework/boot/logging/logback/base.xml"/>

    <!-- 操作日志文件：按天滚动，保留30天 -->
    <appender name="OPERATION_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>/data/pet-adoption/logs/operation.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>/data/pet-adoption/logs/operation.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 操作日志专用 Logger，不继承 root 的 appender -->
    <logger name="OPERATION_LOG" level="INFO" additivity="false">
        <appender-ref ref="OPERATION_FILE"/>
    </logger>
</configuration>
