<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pet.module.system.mapper.UserNoticeReadMapper">

    <resultMap id="BaseResultMap" type="com.pet.module.system.model.entity.UserNoticeRead">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="notice_id" property="noticeId"/>
        <result column="read_at" property="readAt"/>
    </resultMap>

    <sql id="BaseColumns">id, user_id, notice_id, read_at</sql>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user_notice_read (user_id, notice_id) VALUES (#{userId}, #{noticeId})
    </insert>

    <select id="selectByUserAndNotice" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/> FROM user_notice_read WHERE user_id = #{userId} AND notice_id = #{noticeId}
    </select>

    <select id="selectReadNoticeIdsByUserId" resultType="java.lang.Long">
        SELECT notice_id FROM user_notice_read WHERE user_id = #{userId}
    </select>
</mapper>
