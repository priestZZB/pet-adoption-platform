<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pet.module.system.mapper.BannerMapper">

    <resultMap id="BaseResultMap" type="com.pet.module.system.model.entity.Banner">
        <id column="id" property="id"/>
        <result column="image_url" property="imageUrl"/>
        <result column="title" property="title"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <sql id="BaseColumns">
        id, image_url, title, sort_order, created_at
    </sql>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO banner (image_url, title, sort_order)
        VALUES (#{imageUrl}, #{title}, #{sortOrder})
    </insert>

    <update id="updateById">
        UPDATE banner
        <set>
            <if test="imageUrl != null">image_url = #{imageUrl},</if>
            <if test="title != null">title = #{title},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">DELETE FROM banner WHERE id = #{id}</delete>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/> FROM banner WHERE id = #{id}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/> FROM banner ORDER BY sort_order ASC, id ASC
    </select>
</mapper>
