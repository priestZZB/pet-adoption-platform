# ==========================================
# 宠物领养救助管理平台 — 环境变量参考
# 复制此文件为 .env 并填入真实值
# ==========================================

# DeepSeek AI
DEEPSEEK_API_KEY=***

# JWT 密钥
JWT_SECRET=your-jwt-secret

# 第三方服务 AppCode
APPCODE=your-appcode

# 滑块验证码
CAPTCHA_APP_ID=your-app-id
CAPTCHA_APP_SECRET=***

# 短信服务
SMS_TEMPLATE_ID=your-template-id
SMS_SIGN_ID=your-sign-id

# 数据库
DB_PASSWORD=***
