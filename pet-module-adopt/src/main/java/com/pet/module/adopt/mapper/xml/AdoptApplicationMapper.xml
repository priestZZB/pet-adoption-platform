<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pet.module.adopt.mapper.AdoptApplicationMapper">

    <resultMap id="BaseResultMap" type="com.pet.module.adopt.model.entity.AdoptApplication">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="pet_id" property="petId"/>
        <result column="living_env" property="livingEnv"/>
        <result column="pet_exp" property="petExp"/>
        <result column="commitment" property="commitment"/>
        <result column="status" property="status"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <sql id="BaseColumns">
        id, user_id, pet_id, living_env, pet_exp, commitment, status, created_at, updated_at
    </sql>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO adopt_application (user_id, pet_id, living_env, pet_exp, commitment, status)
        VALUES (#{userId}, #{petId}, #{livingEnv}, #{petExp}, #{commitment}, #{status})
    </insert>

    <update id="updateById">
        UPDATE adopt_application
        <set>
            <if test="status != null">status = #{status},</if>
        </set>
        WHERE id = #{id}
    </update>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/> FROM adopt_application WHERE id = #{id}
    </select>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/> FROM adopt_application WHERE user_id = #{userId} ORDER BY created_at DESC
    </select>

    <select id="selectByPetId" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/> FROM adopt_application WHERE pet_id = #{petId} ORDER BY created_at DESC
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/> FROM adopt_application
        <where>
            <if test="status != null and status != ''">AND status = #{status}</if>
        </where>
        ORDER BY created_at DESC
    </select>

    <select id="countActiveByUserAndPet" resultType="int">
        SELECT COUNT(*) FROM adopt_application
        WHERE user_id = #{userId} AND pet_id = #{petId} AND status != 'REJECTED'
    </select>

    <!-- ========== Dashboard 统计 ========== -->
    <select id="countAll" resultType="int">
        SELECT COUNT(*) FROM adopt_application
    </select>

    <select id="countByStatus" resultType="int">
        SELECT COUNT(*) FROM adopt_application WHERE status = #{status}
    </select>

    <select id="countApproved" resultType="int">
        SELECT COUNT(*) FROM adopt_application
        WHERE user_id = #{userId} AND pet_id = #{petId} AND status = 'APPROVED'
    </select>
</mapper>