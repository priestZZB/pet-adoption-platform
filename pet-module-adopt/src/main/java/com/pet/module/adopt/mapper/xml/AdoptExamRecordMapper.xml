<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pet.module.adopt.mapper.AdoptExamRecordMapper">

    <resultMap id="BaseResultMap" type="com.pet.module.adopt.model.entity.AdoptExamRecord">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="score" property="score"/>
        <result column="total_questions" property="totalQuestions"/>
        <result column="is_passed" property="isPassed"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <sql id="BaseColumns">
        id, user_id, score, total_questions, is_passed, created_at
    </sql>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO adopt_exam_record (user_id, score, total_questions, is_passed)
        VALUES (#{userId}, #{score}, #{totalQuestions}, #{isPassed})
    </insert>

    <select id="selectLatestByUserId" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM adopt_exam_record
        WHERE user_id = #{userId}
        ORDER BY created_at DESC
        LIMIT 1
    </select>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM adopt_exam_record
        WHERE user_id = #{userId}
        ORDER BY created_at DESC
    </select>
</mapper>