<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pet.module.mall.mapper.MallOrderItemMapper">

    <resultMap id="BaseResultMap" type="com.pet.module.mall.model.entity.MallOrderItem">
        <id column="id" property="id"/>
        <result column="order_id" property="orderId"/>
        <result column="product_id" property="productId"/>
        <result column="product_name" property="productName"/>
        <result column="product_image" property="productImage"/>
        <result column="quantity" property="quantity"/>
        <result column="price" property="price"/>
    </resultMap>

    <sql id="BaseColumns">
        id, order_id, product_id, product_name, product_image, quantity, price
    </sql>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO mall_order_item (order_id, product_id, product_name, product_image, quantity, price)
        VALUES (#{orderId}, #{productId}, #{productName}, #{productImage}, #{quantity}, #{price})
    </insert>

    <insert id="insertBatch">
        INSERT INTO mall_order_item (order_id, product_id, product_name, product_image, quantity, price)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.orderId}, #{item.productId}, #{item.productName}, #{item.productImage}, #{item.quantity}, #{item.price})
        </foreach>
    </insert>

    <select id="selectByOrderId" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/> FROM mall_order_item WHERE order_id = #{orderId}
    </select>

    <select id="selectByOrderIds" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/> FROM mall_order_item WHERE order_id IN
        <foreach collection="list" item="id" open="(" separator="," close=")">#{id}</foreach>
    </select>
</mapper>