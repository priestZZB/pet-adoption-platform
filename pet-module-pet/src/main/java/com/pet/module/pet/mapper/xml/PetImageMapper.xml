<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pet.module.pet.mapper.PetImageMapper">

    <resultMap id="BaseResultMap" type="com.pet.module.pet.model.entity.PetImage">
        <id column="id" property="id"/>
        <result column="pet_id" property="petId"/>
        <result column="image_url" property="imageUrl"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <sql id="BaseColumns">
        id, pet_id, image_url, sort_order, created_at
    </sql>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO pet_image (pet_id, image_url, sort_order)
        VALUES (#{petId}, #{imageUrl}, #{sortOrder})
    </insert>

    <insert id="insertBatch">
        INSERT INTO pet_image (pet_id, image_url, sort_order) VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.petId}, #{item.imageUrl}, #{item.sortOrder})
        </foreach>
    </insert>

    <delete id="deleteByPetId">DELETE FROM pet_image WHERE pet_id = #{petId}</delete>

    <select id="selectByPetId" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/> FROM pet_image WHERE pet_id = #{petId} ORDER BY sort_order ASC
    </select>
</mapper>