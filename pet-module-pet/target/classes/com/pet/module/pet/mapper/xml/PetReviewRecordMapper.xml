<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pet.module.pet.mapper.PetReviewRecordMapper">

    <resultMap id="BaseResultMap" type="com.pet.module.pet.model.entity.PetReviewRecord">
        <id column="id" property="id"/>
        <result column="pet_id" property="petId"/>
        <result column="reviewer_id" property="reviewerId"/>
        <result column="review_type" property="reviewType"/>
        <result column="action" property="action"/>
        <result column="remark" property="remark"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <sql id="BaseColumns">
        id, pet_id, reviewer_id, review_type, action, remark, created_at
    </sql>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO pet_review_record (pet_id, reviewer_id, review_type, action, remark)
        VALUES (#{petId}, #{reviewerId}, #{reviewType}, #{action}, #{remark})
    </insert>

    <select id="selectByPetId" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/> FROM pet_review_record WHERE pet_id = #{petId} ORDER BY created_at ASC
    </select>

    <select id="selectReviewerPetIds" resultType="java.lang.Long">
        SELECT DISTINCT pet_id FROM pet_review_record WHERE reviewer_id = #{reviewerId}
    </select>
</mapper>