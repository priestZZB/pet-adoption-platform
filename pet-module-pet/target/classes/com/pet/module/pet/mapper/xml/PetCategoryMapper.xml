<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pet.module.pet.mapper.PetCategoryMapper">

    <resultMap id="BaseResultMap" type="com.pet.module.pet.model.entity.PetCategory">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <sql id="BaseColumns">
        id, name, sort_order, created_at
    </sql>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO pet_category (name, sort_order)
        VALUES (#{name}, #{sortOrder})
    </insert>

    <update id="updateById">
        UPDATE pet_category
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">DELETE FROM pet_category WHERE id = #{id}</delete>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/> FROM pet_category WHERE id = #{id}
    </select>

    <select id="selectList" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/> FROM pet_category ORDER BY sort_order ASC, id ASC
    </select>
</mapper>